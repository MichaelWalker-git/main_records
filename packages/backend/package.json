    "bwip-js": "^4.1.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "pg": "^8.12.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.0"
  },
