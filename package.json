{
  "name": "maine-rms",
  "version": "1.0.0",
  "private": true,
  "description": "Maine Records Management System - State of Maine RFP# 202603058",
  "workspaces": [
    "packages/shared",
    "packages/infrastructure",
    "packages/backend",
    "packages/lambdas/*",
    "packages/frontend",
    "packages/e2e"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "deploy": "./scripts/deploy.sh",
    "seed": "./scripts/seed-db.sh"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
